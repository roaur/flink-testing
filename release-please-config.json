{
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
    "packages": {
        "db-writer": {
            "release-type": "simple",
            "package-name": "db-writer"
        },
        "flink": {
            "release-type": "simple",
            "package-name": "flink"
        },
        "postgres": {
            "release-type": "simple",
            "package-name": "postgres"
        },
        "flink-jobs": {
            "release-type": "simple",
            "package-name": "flink-jobs"
        }
    },
    "plugins": [
        {
            "type": "linked-versions",
            "groupName": "flink-testing-suite",
